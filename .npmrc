# The Claude Agent SDK (@anthropic-ai/claude-agent-sdk) peer-requires zod ^4, but the
# shared/ API contract is built on zod ^3.23 (upgrading would churn every schema +
# contract test). zod 3.25 satisfies the SDK at runtime (verified: query/AbortError
# load and typecheck), so we accept the peer mismatch rather than destabilize the
# contract. See RUN_LOG DECISION (G7 credential/SDK). Remove if the contract moves to zod 4.
legacy-peer-deps=true
