{
  "name": "@ekoa/api",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run --passWithNoTests",
    "test:contract": "vitest run tests/contract",
    "dev": "node --watch --loader ts-node/esm src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@ekoa/shared": "*",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "docx": "^9.7.1",
    "esbuild": "^0.27.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.10.0",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.61.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "^7.18.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.6",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2"
  }
}
