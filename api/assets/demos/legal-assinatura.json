{
  "version": 1,
  "appId": "legal-assinatura",
  "card": {
    "titlePt": "Assinatura Qualificada",
    "descriptionPt": "Prepare um envelope de assinatura a partir de uma procuração forense fictícia, defina a ordem dos signatários, assine em modo simulado e arquive o certificado de auditoria no dossiê. O calendário da Portaria 350-A/2025 mostra a passagem à assinatura qualificada obrigatória em 2027.",
    "durationSec": 100
  },
  "steps": [
    {
      "id": "abrir-envelopes",
      "type": "navigate",
      "to": "/",
      "copy": {
        "titlePt": "Envelopes de assinatura",
        "bodyPt": "Este é o painel de envelopes. Em destaque, o calendário que leva à assinatura qualificada obrigatória a partir de 1 de janeiro de 2027."
      }
    },
    {
      "id": "destacar-calendario",
      "type": "spotlight",
      "target": "assinatura-calendario",
      "copy": {
        "titlePt": "O calendário de 2027",
        "bodyPt": "Até 31 de dezembro de 2026 admite-se a assinatura avançada para advogados; a partir de 2027 passa a ser obrigatória a qualificada, com a fonte citada (Portaria n.º 350-A/2025)."
      }
    },
    {
      "id": "ir-novo",
      "type": "navigate",
      "to": "/novo",
      "copy": {
