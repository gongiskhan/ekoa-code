# ekoa-code staging environment - COPY to deploy/staging/.env on the VM and fill in.
# deploy/staging/.env is gitignored and must never be committed. Set mode 600 on the VM.
# Generate the three secrets fresh for staging (do NOT reuse production's):
#     JWT_SECRET=$(openssl rand -hex 32)
#     ENCRYPTION_KEY=$(openssl rand -hex 32)   # any strong string; api SHA-256s it (data/crypto.ts)
#     MONGO_PASSWORD=$(openssl rand -hex 24)

# ---- Edge / public identity (consumed by docker-compose.yml interpolation + Caddy) ----------
# The public origin the browser is served from and calls the API on (same-origin behind Caddy).
PUBLIC_ORIGIN=https://staging.ekoa.io
# The hostname Caddy serves and requests a Let's Encrypt cert for (host part of PUBLIC_ORIGIN).
PUBLIC_HOSTNAME=staging.ekoa.io
# ACME account email for the issued cert.
ACME_EMAIL=goncalo@ekoa.io

# ---- Datastore (Mongo) ----------------------------------------------------------------------
# Single source of truth for the DB password. docker-compose seeds the mongo root user with it
# and assembles MONGODB_URI from it - do NOT also set MONGODB_URI here.
# (Value FILL_ME is a placeholder; generate with `openssl rand -hex 24`.)
MONGO_PASSWORD=FILL_ME

# ---- API runtime secrets (injected into the api container via env_file) ---------------------
# Mandatory - the api fails closed at boot without these (api/src/config.ts).
# Generate each with `openssl rand -hex 32`.
JWT_SECRET=FILL_ME
ENCRYPTION_KEY=FILL_ME
# Seeded admin login for the staging dashboard (choose a real password).
EKOA_ADMIN_USERNAME=admin
EKOA_ADMIN_PASSWORD=FILL_ME

# ---- Model credential -----------------------------------------------------------------------
# NOT set here. The provider credential is stored (AES-encrypted) in Mongo via the setCredential
# seam, provisioned ONCE after boot with provision-credential.mjs using an Anthropic API key
# (or OAuth token) tied to goncalo@ekoa.io. See deploy/staging/README.md. Because staging Mongo
# is persistent, it survives restarts and only needs provisioning once (unlike the dev harness).

# ---- Optional integrations (leave unset on staging unless a flow is being exercised) --------
# Microsoft / Adobe / Zoho / Google OAuth + GitHub App credentials degrade gracefully when
# absent. Enabling any requires registering staging redirect URIs with that provider.
# GITHUB_PUSH_ENABLED=false
