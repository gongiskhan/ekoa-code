  { "type": "text", "id": "choke10_t", "x": 592, "y": 194, "width": 356, "height": 34, "text": "llm/ egress module (FIXED-13)\ndetectors: (a) IDs+checksum (b) deny-list (c) NER", "originalText": "llm/ egress module (FIXED-13)\ndetectors: (a) IDs+checksum (b) deny-list (c) NER", "fontSize": 11, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1020003, "version": 1, "versionNonce": 1020004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "choke10", "lineHeight": 1.25 },
  { "type": "rectangle", "id": "vault", "x": 580, "y": 276, "width": 380, "height": 56, "strokeColor": "#b45309", "backgroundColor": "#fef3c7", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1020005, "version": 1, "versionNonce": 1020006, "isDeleted": false, "groupIds": [], "boundElements": [ { "id": "vault_t", "type": "text" } ], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "vault_t", "x": 592, "y": 288, "width": 356, "height": 32, "text": "session vault: token <-> value, in-memory, TTL\nNEVER persisted (D1) - never crosses any boundary", "originalText": "session vault: token <-> value, in-memory, TTL\nNEVER persisted (D1) - never crosses any boundary", "fontSize": 10.5, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#78350f", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1020007, "version": 1, "versionNonce": 1020008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "vault", "lineHeight": 1.25 },
  { "type": "rectangle", "id": "denylist", "x": 580, "y": 364, "width": 380, "height": 36, "strokeColor": "#1e40af", "backgroundColor": "#dbeafe", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1020009, "version": 1, "versionNonce": 1020010, "isDeleted": false, "groupIds": [], "boundElements": [ { "id": "denylist_t", "type": "text" } ], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "denylist_t", "x": 590, "y": 374, "width": 360, "height": 14, "text": "org deny-list: encrypted, org-scoped key (D3)\nloaded per-org at the composition root (F10 wired)\nCRUD /api/v1/org/deny-list (org-admin, metadata-only)", "originalText": "org deny-list: encrypted, org-scoped key (D3)\nloaded per-org at the composition root (F10 wired)\nCRUD /api/v1/org/deny-list (org-admin, metadata-only)", "fontSize": 10, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1020011, "version": 1, "versionNonce": 1020012, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "denylist", "lineHeight": 1.25 },
