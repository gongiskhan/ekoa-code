  { "type": "text", "id": "audit_box_t", "x": 592, "y": 440, "width": 360, "height": 66, "text": "audit: hash-chained METADATA only (D2) -> Registo\n{classes: [NIF, PERSON], counts: {NIF:1, PERSON:1},\n corrId: c-7f3a, payloadHash: 41c2} - never bodies,\n never the vault", "originalText": "audit: hash-chained METADATA only (D2) -> Registo\n{classes: [NIF, PERSON], counts: {NIF:1, PERSON:1},\n corrId: c-7f3a, payloadHash: 41c2} - never bodies,\n never the vault", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#e2e8f0", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1020015, "version": 1, "versionNonce": 1020016, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
