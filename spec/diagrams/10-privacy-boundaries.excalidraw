  { "type": "text", "id": "subtitle", "x": 60, "y": 58, "width": 1200, "height": 18, "text": "Two trust boundaries (ch17, ch18). Files never leave as files; the vault never crosses either boundary.", "originalText": "Two trust boundaries (ch17, ch18). Files never leave as files; the vault never crosses either boundary.", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1000003, "version": 1, "versionNonce": 1000004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

