  { "type": "text", "id": "tuple_box_t", "x": 552, "y": 282, "width": 350, "height": 66, "text": "delegated task - binds (S2):\n{tenant: t-01, user: u-07, session: s-42,\n pairing: p-9c, grant_refs: [g-3],\n budget: 10MB, expiry: +15m, nonce: 8f21}", "originalText": "delegated task - binds (S2):\n{tenant: t-01, user: u-07, session: s-42,\n pairing: p-9c, grant_refs: [g-3],\n budget: 10MB, expiry: +15m, nonce: 8f21}", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#e2e8f0", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1100021, "version": 1, "versionNonce": 1100022, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

