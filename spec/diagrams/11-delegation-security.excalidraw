  { "type": "text", "id": "a_result_label", "x": 545, "y": 416, "width": 380, "height": 14, "text": "derived output only (I2) + ledger refs + telemetry", "originalText": "derived output only (I2) + ledger refs + telemetry", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#047857", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1100025, "version": 1, "versionNonce": 1100026, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

  { "type": "rectangle", "id": "agent_pill", "x": 80, "y": 186, "width": 390, "height": 50, "strokeColor": "#6d28d9", "backgroundColor": "#ddd6fe", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110001, "version": 1, "versionNonce": 1110002, "isDeleted": false, "groupIds": [], "boundElements": [ { "id": "agent_pill_t", "type": "text" } ], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "agent_pill_t", "x": 92, "y": 196, "width": 366, "height": 30, "text": "hosted agent run - tool:\ndelegate_to_local(task, grant_refs, budget)", "originalText": "hosted agent run - tool:\ndelegate_to_local(task, grant_refs, budget)", "fontSize": 10.5, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110003, "version": 1, "versionNonce": 1110004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "agent_pill", "lineHeight": 1.25 },
  { "type": "rectangle", "id": "choke_pill", "x": 80, "y": 256, "width": 390, "height": 52, "strokeColor": "#6d28d9", "backgroundColor": "#ddd6fe", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110005, "version": 1, "versionNonce": 1110006, "isDeleted": false, "groupIds": [], "boundElements": [ { "id": "choke_pill_t", "type": "text" } ], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "choke_pill_t", "x": 92, "y": 266, "width": 366, "height": 30, "text": "llm/ chokepoint: corrId minted per request (S6)\nprovider endpoint: pairing-bound credential (18.4)", "originalText": "llm/ chokepoint: corrId minted per request (S6)\nprovider endpoint: pairing-bound credential (18.4)", "fontSize": 10, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110007, "version": 1, "versionNonce": 1110008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "choke_pill", "lineHeight": 1.25 },
  { "type": "rectangle", "id": "pairing_pill", "x": 80, "y": 328, "width": 390, "height": 52, "strokeColor": "#1e40af", "backgroundColor": "#dbeafe", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110009, "version": 1, "versionNonce": 1110010, "isDeleted": false, "groupIds": [], "boundElements": [ { "id": "pairing_pill_t", "type": "text" } ], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "pairing_pill_t", "x": 92, "y": 338, "width": 366, "height": 30, "text": "pairing registry: tenant-scoped {pairing, tenant, user}\nrevoke = server-side kill switch (S4)", "originalText": "pairing registry: tenant-scoped {pairing, tenant, user}\nrevoke = server-side kill switch (S4)", "fontSize": 10, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110011, "version": 1, "versionNonce": 1110012, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "pairing_pill", "lineHeight": 1.25 },
  { "type": "rectangle", "id": "derived_pill", "x": 80, "y": 400, "width": 390, "height": 52, "strokeColor": "#047857", "backgroundColor": "#a7f3d0", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110013, "version": 1, "versionNonce": 1110014, "isDeleted": false, "groupIds": [], "boundElements": [ { "id": "derived_pill_t", "type": "text" } ], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "derived_pill_t", "x": 92, "y": 410, "width": 366, "height": 30, "text": "conversation records accept derived output only (I2)\nsummaries | citations path+range | patches | refs", "originalText": "conversation records accept derived output only (I2)\nsummaries | citations path+range | patches | refs", "fontSize": 10, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110015, "version": 1, "versionNonce": 1110016, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "derived_pill", "lineHeight": 1.25 },
  { "type": "text", "id": "untrusted_note", "x": 80, "y": 490, "width": 400, "height": 42, "text": "every Cortex payload is UNTRUSTED input to the daemon:\na compromised Cortex cannot widen a grant, bypass a\nconfirmation, or escape granted roots (S1)", "originalText": "every Cortex payload is UNTRUSTED input to the daemon:\na compromised Cortex cannot widen a grant, bypass a\nconfirmation, or escape granted roots (S1)", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#b91c1c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110017, "version": 1, "versionNonce": 1110018, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

  { "type": "text", "id": "checklist", "x": 970, "y": 186, "width": 450, "height": 168, "text": "on every delegated task, daemon-side:\n1 verify binding: pairing, expiry, nonce\n  (replay cache) - reject unknowns (S2)\n2 grant_refs exist + belong to this session (S2)\n3 every path through ONE containment resolver:\n  realpath, symlink-escape rejected (S1)\n4 fixed file-tool vocabulary on the chat path (S3)\n  local_command stays executor-face, consent-gated\n5 egress cap; every read AND every denial\n  ledgered, append-only (S5, S6)", "originalText": "on every delegated task, daemon-side:\n1 verify binding: pairing, expiry, nonce\n  (replay cache) - reject unknowns (S2)\n2 grant_refs exist + belong to this session (S2)\n3 every path through ONE containment resolver:\n  realpath, symlink-escape rejected (S1)\n4 fixed file-tool vocabulary on the chat path (S3)\n  local_command stays executor-face, consent-gated\n5 egress cap; every read AND every denial\n  ledgered, append-only (S5, S6)", "fontSize": 10.5, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110019, "version": 1, "versionNonce": 1110020, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
  { "type": "text", "id": "channel_note", "x": 970, "y": 380, "width": 450, "height": 28, "text": "channel: dials OUT, TLS, pairing-token auth, heartbeat,\nrate-limited, revocable from BOTH ends (S4)", "originalText": "channel: dials OUT, TLS, pairing-token auth, heartbeat,\nrate-limited, revocable from BOTH ends (S4)", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110021, "version": 1, "versionNonce": 1110022, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
  { "type": "text", "id": "injection_note", "x": 970, "y": 424, "width": 450, "height": 42, "text": "prompt injection in a granted file is CONTAINED by\nconstruction: no upload primitive exists, out-of-grant\nreads denied + ledgered, egress cap holds (S5)", "originalText": "prompt injection in a granted file is CONTAINED by\nconstruction: no upload primitive exists, out-of-grant\nreads denied + ledgered, egress cap holds (S5)", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1110023, "version": 1, "versionNonce": 1110024, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

  { "type": "rectangle", "id": "adv_frame", "x": 60, "y": 620, "width": 1370, "height": 160, "strokeColor": "#b91c1c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "dashed", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1120001, "version": 1, "versionNonce": 1120002, "isDeleted": false, "groupIds": [], "boundElements": [], "link": null, "locked": false, "roundness": { "type": 3 } },
  { "type": "text", "id": "adv_title", "x": 76, "y": 630, "width": 900, "height": 16, "text": "fake-daemon adversarial scenarios (18.7) - every one MUST be rejected and ledgered:", "originalText": "fake-daemon adversarial scenarios (18.7) - every one MUST be rejected and ledgered:", "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#b91c1c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1120003, "version": 1, "versionNonce": 1120004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
  { "type": "text", "id": "adv_col1", "x": 80, "y": 658, "width": 620, "height": 100, "text": "replayed task            -> rejected (nonce cache)\nexpired task             -> rejected\ngrant_ref of another session -> rejected\nforged / wrong pairing   -> rejected at connect\nsymlink escape / traversal   -> rejected + ledgered", "originalText": "replayed task            -> rejected (nonce cache)\nexpired task             -> rejected\ngrant_ref of another session -> rejected\nforged / wrong pairing   -> rejected at connect\nsymlink escape / traversal   -> rejected + ledgered", "fontSize": 10.5, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1120005, "version": 1, "versionNonce": 1120006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
  { "type": "text", "id": "adv_col2", "x": 740, "y": 658, "width": 680, "height": 100, "text": "cross-tenant addressing    -> impossible by construction\nstolen provider credential -> cannot reach another vault\ninjection in file content  -> contained, no exfil (S5)\nrevoke pairing mid-session -> disconnect, delegation fails\nall denials                -> ledgered (S6)", "originalText": "cross-tenant addressing    -> impossible by construction\nstolen provider credential -> cannot reach another vault\ninjection in file content  -> contained, no exfil (S5)\nrevoke pairing mid-session -> disconnect, delegation fails\nall denials                -> ledgered (S6)", "fontSize": 10.5, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1120007, "version": 1, "versionNonce": 1120008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

  { "type": "text", "id": "s6_note", "x": 60, "y": 800, "width": 1370, "height": 30, "text": "S6 audit join: the correlation id flows chokepoint -> delegation -> daemon ledger, joining local rows with hosted audit metadata (ch17.6).\npayload-capture assertions run against the fake daemon: planted synthetic values appear tokenized in EVERY captured outbound Anthropic request.", "originalText": "S6 audit join: the correlation id flows chokepoint -> delegation -> daemon ledger, joining local rows with hosted audit metadata (ch17.6).\npayload-capture assertions run against the fake daemon: planted synthetic values appear tokenized in EVERY captured outbound Anthropic request.", "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#047857", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1120009, "version": 1, "versionNonce": 1120010, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 }
 ]
}
