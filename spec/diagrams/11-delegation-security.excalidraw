  { "type": "text", "id": "ws_label", "x": 545, "y": 200, "width": 360, "height": 14, "text": "one outbound WS from the daemon (TLS, pairing)", "originalText": "one outbound WS from the daemon (TLS, pairing)", "fontSize": 10, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1100013, "version": 1, "versionNonce": 1100014, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
