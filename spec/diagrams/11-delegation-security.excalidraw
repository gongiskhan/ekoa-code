  { "type": "text", "id": "title", "x": 60, "y": 24, "width": 980, "height": 30, "text": "11 - Delegation security: the S1-S6 bindings", "originalText": "11 - Delegation security: the S1-S6 bindings", "fontSize": 24, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#1e40af", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1100001, "version": 1, "versionNonce": 1100002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
  { "type": "text", "id": "subtitle", "x": 60, "y": 58, "width": 1300, "height": 18, "text": "The daemon enforces; Cortex is untrusted input to it (ch18.5). The fake daemon (api/test/fake-daemon/) is the executable contract.", "originalText": "The daemon enforces; Cortex is untrusted input to it (ch18.5). The fake daemon (api/test/fake-daemon/) is the executable contract.", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 1100003, "version": 1, "versionNonce": 1100004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

