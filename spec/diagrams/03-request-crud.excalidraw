      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 33337,
      "version": 1,
      "versionNonce": 1,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "refresh: authed -> re-sign claims, fresh jti (old token valid to ITS expiry)\nlogout self: revoke(jti) -> next request 401 | admin {userId}: super-admin any,\n  org-admin own org only (cross-org reads not-found); target tokenEpoch bumped\npassword self: verify current -> hash new -> passwordChangeRequired=false\nusers/:id/password (super-admin): reset -> passwordChangeRequired=true\ndevice flow (mongo device_auth, single-use):\n  start(public) -> pending{deviceCode,userCode,600s}\n  approve(authed userCode) -> approved(binds approver) | denied\n  poll(public deviceCode) -> pending|slow_down(<5s)|denied|expired\n                             |approved{token,user} CONSUMES row (one mint)",
      "rawText": "refresh: authed -> re-sign claims, fresh jti (old token valid to ITS expiry)\nlogout self: revoke(jti) -> next request 401 | admin {userId}: super-admin any,\n  org-admin own org only (cross-org reads not-found); target tokenEpoch bumped\npassword self: verify current -> hash new -> passwordChangeRequired=false\nusers/:id/password (super-admin): reset -> passwordChangeRequired=true\ndevice flow (mongo device_auth, single-use):\n  start(public) -> pending{deviceCode,userCode,600s}\n  approve(authed userCode) -> approved(binds approver) | denied\n  poll(public deviceCode) -> pending|slow_down(<5s)|denied|expired\n                             |approved{token,user} CONSUMES row (one mint)",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "refresh: authed -> re-sign claims, fresh jti (old token valid to ITS expiry)\nlogout self: revoke(jti) -> next request 401 | admin {userId}: super-admin any,\n  org-admin own org only (cross-org reads not-found); target tokenEpoch bumped\npassword self: verify current -> hash new -> passwordChangeRequired=false\nusers/:id/password (super-admin): reset -> passwordChangeRequired=true\ndevice flow (mongo device_auth, single-use):\n  start(public) -> pending{deviceCode,userCode,600s}\n  approve(authed userCode) -> approved(binds approver) | denied\n  poll(public deviceCode) -> pending|slow_down(<5s)|denied|expired\n                             |approved{token,user} CONSUMES row (one mint)",
      "autoResize": true,
      "lineHeight": 1.25
    }
  ]
