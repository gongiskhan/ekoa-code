    {
      "type": "text",
      "id": "verify_body",
      "x": 795,
      "y": 528,
      "width": 366,
      "height": 96,
      "text": "after the version snapshot, before complete:\n1. honest-completion gate (F16, deterministic):\n   entrypoint untouched / dist = scaffold -> FAIL\n2. post-build verify (F28, default ON): playwright-cli\n   asserts REQUEST-FULFILMENT (scaffold DOM = FAIL);\n   ran+failed -> FAIL terminal; not-run -> honest note",
      "originalText": "runs after the artifact's version snapshot,\nbefore the job completes:\nplaywright-cli, medium depth, incremental;\nverifying agent fixes forward in-budget;\ncan't fix -> complete + honest visible note",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 710005,
      "version": 1,
      "versionNonce": 710006,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25,
      "rawText": "after the version snapshot, before complete:\n1. honest-completion gate (F16, deterministic):\n   entrypoint untouched / dist = scaffold -> FAIL\n2. post-build verify (F28, default ON): playwright-cli\n   asserts REQUEST-FULFILMENT (scaffold DOM = FAIL);\n   ran+failed -> FAIL terminal; not-run -> honest note"
    },
